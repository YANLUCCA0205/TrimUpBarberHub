{
  "name": "Barber",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Nome"
    },
    "shop_id": {
      "type": "string",
      "title": "ID da Barbearia"
    },
    "photo": {
      "type": "string",
      "title": "Foto"
    },
    "bio": {
      "type": "string",
      "title": "Quem sou eu / Bio"
    },
    "career": {
      "type": "string",
      "title": "Carreira e Experi\u00eancia"
    },
    "specialties": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Especialidades"
    },
    "rating": {
      "type": "number",
      "title": "Avalia\u00e7\u00e3o",
      "minimum": 0,
      "maximum": 5
    },
    "total_reviews": {
      "type": "number",
      "title": "Total de Avalia\u00e7\u00f5es",
      "default": 0
    },
    "city": {
      "type": "string",
      "title": "Cidade"
    },
    "neighborhood": {
      "type": "string",
      "title": "Bairro"
    },
    "instagram": {
      "type": "string",
      "title": "Instagram"
    },
    "whatsapp": {
      "type": "string",
      "title": "WhatsApp"
    },
    "is_active": {
      "type": "boolean",
      "title": "Ativo",
      "default": true
    },
    "total_clients": {
      "type": "number",
      "title": "Total de Clientes",
      "default": 0
    },
    "retention_rate": {
      "type": "number",
      "title": "Taxa de Reten\u00e7\u00e3o",
      "default": 0
    },
    "monthly_revenue": {
      "type": "number",
      "title": "Faturamento Mensal",
      "default": 0
    },
    "owner_email": {
      "type": "string",
      "title": "Email do Propriet\u00e1rio"
    },
    "portfolio": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Portf\u00f3lio"
    },
    "working_hours": {
      "type": "object",
      "title": "Hor\u00e1rio de Funcionamento"
    }
  },
  "required": [
    "name",
    "owner_email"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        {
          "data.owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.owner_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}