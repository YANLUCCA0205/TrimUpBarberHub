{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Nome completo"
    },
    "phone": {
      "type": "string",
      "title": "Telefone"
    },
    "whatsapp": {
      "type": "string",
      "title": "WhatsApp"
    },
    "email": {
      "type": "string",
      "title": "Email"
    },
    "street": {
      "type": "string",
      "title": "Rua"
    },
    "street_number": {
      "type": "string",
      "title": "N\u00famero"
    },
    "complement": {
      "type": "string",
      "title": "Complemento"
    },
    "neighborhood": {
      "type": "string",
      "title": "Bairro"
    },
    "city": {
      "type": "string",
      "title": "Cidade"
    },
    "cep": {
      "type": "string",
      "title": "CEP"
    },
    "state": {
      "type": "string",
      "title": "Estado"
    },
    "notes": {
      "type": "string",
      "title": "Observa\u00e7\u00f5es"
    },
    "shop_id": {
      "type": "string",
      "title": "ID da Barbearia"
    },
    "barber_id": {
      "type": "string",
      "title": "Barbeiro preferido"
    },
    "birthday": {
      "type": "string",
      "title": "Data de nascimento"
    },
    "preferred_services": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Servi\u00e7os preferidos"
    },
    "total_visits": {
      "type": "number",
      "title": "Total de visitas",
      "default": 0
    },
    "total_spent": {
      "type": "number",
      "title": "Total gasto",
      "default": 0
    },
    "avg_ticket": {
      "type": "number",
      "title": "Ticket m\u00e9dio",
      "default": 0
    },
    "last_visit": {
      "type": "string",
      "title": "\u00daltima visita"
    },
    "source": {
      "type": "string",
      "title": "Origem",
      "enum": [
        "indica\u00e7\u00e3o",
        "instagram",
        "google",
        "passagem",
        "whatsapp",
        "outro"
      ]
    },
    "is_vip": {
      "type": "boolean",
      "title": "Cliente VIP",
      "default": false
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "siteowner"
          }
        },
        {
          "data.shop_id": "{{user.ownedShopId}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "siteowner"
          }
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.email": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "siteowner"
          }
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.email": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "siteowner"
          }
        }
      ]
    }
  }
}