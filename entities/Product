{
  "name": "Product",
  "type": "object",
  "properties": {
    "barber_id": {
      "type": "string",
      "title": "ID do Barbeiro"
    },
    "name": {
      "type": "string",
      "title": "Nome"
    },
    "description": {
      "type": "string",
      "title": "Descri\u00e7\u00e3o"
    },
    "price": {
      "type": "number",
      "title": "Pre\u00e7o"
    },
    "image": {
      "type": "string",
      "title": "Imagem"
    },
    "category": {
      "type": "string",
      "title": "Categoria",
      "enum": [
        "pomada",
        "\u00f3leo",
        "perfume",
        "shampoo",
        "condicionador",
        "m\u00e1quina",
        "acess\u00f3rio",
        "kit"
      ]
    },
    "stock": {
      "type": "number",
      "title": "Estoque",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "title": "Ativo",
      "default": true
    }
  },
  "required": [
    "barber_id",
    "name",
    "price"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.barber_id": "{{user.ownedBarberId}}"
        }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.barber_id": "{{user.ownedBarberId}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.barber_id": "{{user.ownedBarberId}}"
        }
      ]
    }
  }
}