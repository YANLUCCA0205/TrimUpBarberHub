{
  "name": "Subscription",
  "type": "object",
  "properties": {
    "barbershop_id": {
      "type": "string",
      "title": "ID da Barbearia"
    },
    "barbershop_name": {
      "type": "string",
      "title": "Nome da Barbearia"
    },
    "plan_id": {
      "type": "string",
      "title": "ID do Plano"
    },
    "plan_name": {
      "type": "string",
      "title": "Nome do Plano"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "active",
        "trial",
        "cancelled",
        "expired"
      ],
      "default": "active"
    },
    "start_date": {
      "type": "string",
      "title": "Data de In\u00edcio"
    },
    "end_date": {
      "type": "string",
      "title": "Data de Fim"
    },
    "renewal_date": {
      "type": "string",
      "title": "Data de Renova\u00e7\u00e3o"
    },
    "monthly_value": {
      "type": "number",
      "title": "Valor Mensal (R$)",
      "default": 0
    },
    "auto_renew": {
      "type": "boolean",
      "title": "Renova\u00e7\u00e3o Autom\u00e1tica",
      "default": true
    }
  },
  "required": [
    "barbershop_id",
    "plan_id",
    "status"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "siteowner"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "siteowner"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "siteowner"
      }
    },
    "delete": {
      "user_condition": {
        "role": "siteowner"
      }
    }
  }
}